<%# app/views/searches/show.html.erb %>
<div class="container py-4 py-lg-5" style="max-width: 960px;">

  <%= link_to searches_path, class: "d-inline-flex align-items-center gap-1 text-secondary small mb-3" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/></svg>
    Back to searches
  <% end %>

  <div class="card shadow-sm mb-4">
    <div class="card-body p-4">
      <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
        <div style="min-width: 0;">
          <h1 class="h3 fw-bold mb-2"><%= @search.job_title %></h1>
          <% if @search.job_description.present? %>
            <p class="text-secondary mb-0"><%= @search.job_description %></p>
          <% end %>
        </div>
        <div class="btn-group btn-group-sm flex-shrink-0">
          <%= link_to "Edit", edit_search_path(@search), class: "btn btn-outline-secondary" %>
          <%= link_to "Delete", @search,
                class: "btn btn-outline-danger",
                data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
        </div>
      </div>
    </div>
  </div>

  <%# ===== Saved candidates ===== %>
  <div class="d-flex align-items-center gap-2 mb-3">
    <h2 class="h5 fw-bold mb-0">Saved candidates</h2>
    <span class="badge rounded-pill text-bg-primary"><%= @search.candidates.size %></span>
  </div>

  <% if @search.candidates.any? %>
    <div class="row g-3 mb-5">
      <% @search.candidates.each do |candidate| %>
        <div class="col-12 col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
              <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                <h3 class="h6 fw-bold mb-0"><%= candidate.full_name %></h3>
                <%= button_to search_candidate_path(@search, candidate),
                      method: :delete,
                      class: "btn btn-sm btn-outline-danger border-0 p-1 lh-1",
                      form_class: "m-0",
                      title: "Remove",
                      data: { turbo_confirm: "Are you sure?" } do %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                <% end %>
              </div>
              <% if candidate.summary.present? %>
                <p class="text-secondary small mb-3 flex-grow-1"><%= candidate.summary %></p>
              <% end %>
              <div class="d-flex flex-wrap gap-2">
                <% if candidate.linkedin_profile.present? %>
                  <%= link_to candidate.linkedin_profile, target: "_blank", class: "btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/></svg>
                    LinkedIn
                  <% end %>
                <% end %>
                <% if candidate.github_profile.present? %>
                  <%= link_to candidate.github_profile, target: "_blank", class: "btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/></svg>
                    GitHub
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-secondary mb-5">No candidates saved yet. Save the best matches from below.</p>
  <% end %>

  <%# ===== Potential candidates ===== %>
  <div class="d-flex align-items-center gap-2 mb-1">
    <h2 class="h5 fw-bold mb-0">Potential candidates</h2>
    <span class="badge rounded-pill text-bg-secondary"><%= @potential_candidates.size %></span>
  </div>
  <p class="text-secondary small mb-3">Sourced for this search. Save the ones worth keeping.</p>

  <% if @potential_candidates.any? %>
    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th scope="col" class="ps-4 py-3">Candidate</th>
              <th scope="col" class="py-3 text-nowrap">Profiles</th>
              <th scope="col" class="py-3 pe-4 text-end">Action</th>
            </tr>
          </thead>
          <tbody>
            <% @potential_candidates.each do |potential_candidate| %>
              <tr>
                <td class="ps-4 py-3" style="max-width: 440px;">
                  <span class="fw-semibold d-block"><%= potential_candidate.full_name %></span>
                  <% if potential_candidate.summary.present? %>
                    <span class="text-secondary small d-block"><%= potential_candidate.summary %></span>
                  <% end %>
                </td>
                <td class="py-3">
                  <div class="d-flex gap-2">
                    <% if potential_candidate.linkedin_url.present? %>
                      <%= link_to potential_candidate.linkedin_url, target: "_blank", class: "btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/></svg>
                        LinkedIn
                      <% end %>
                    <% end %>
                    <% if potential_candidate.github_url.present? %>
                      <%= link_to potential_candidate.github_url, target: "_blank", class: "btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/></svg>
                        GitHub
                      <% end %>
                    <% end %>
                  </div>
                </td>
                <td class="py-3 pe-4 text-end">
                  <%= button_to "Save as candidate",
                        search_candidates_path(@search, potential_candidate_id: potential_candidate.id),
                        method: :post,
                        class: "btn btn-sm btn-primary text-nowrap",
                        form_class: "m-0 d-inline-block" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <p class="text-secondary">No potential candidates found for this search yet.</p>
  <% end %>

</div>

<%# app/views/searches/index.html.erb %>
<div class="container py-4 py-lg-5" style="max-width: 960px;">

  <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
      <h1 class="h3 fw-bold mb-1">Your searches</h1>
      <p class="text-secondary mb-0">
        <%= pluralize(@searches.size, "active search") %>
      </p>
    </div>
    <%= link_to new_search_path, class: "btn btn-primary d-inline-flex align-items-center gap-2" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/></svg>
      New search
    <% end %>
  </div>

  <% if @searches.any? %>
    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th scope="col" class="ps-4 py-3">Search</th>
              <th scope="col" class="py-3 text-nowrap">Saved candidates</th>
              <th scope="col" class="py-3 text-nowrap">Created</th>
              <th scope="col" class="py-3 pe-4 text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @searches.each do |search| %>
              <tr>
                <td class="ps-4 py-3" style="max-width: 440px;">
                  <%= link_to search.job_title, search_path(search), class: "fw-semibold text-body d-block" %>
                  <% if search.job_description.present? %>
                    <span class="text-secondary small d-block text-truncate">
                      <%= truncate(search.job_description, length: 70) %>
                    </span>
                  <% end %>
                </td>
                <td class="py-3">
                  <span class="badge rounded-pill text-bg-primary fw-semibold">
                    <%= search.candidates.size %>
                  </span>
                </td>
                <td class="py-3 text-secondary text-nowrap">
                  <%= search.created_at.strftime("%b %-d, %Y") %>
                </td>
                <td class="py-3 pe-4 text-end">
                  <div class="btn-group btn-group-sm">
                    <%= link_to "Open", search_path(search), class: "btn btn-outline-secondary" %>
                    <button type="button" class="btn btn-outline-secondary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                      <span class="visually-hidden">Toggle menu</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li><%= link_to "Edit", edit_search_path(search), class: "dropdown-item" %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li>
                        <%= link_to "Delete", search_path(search),
                              class: "dropdown-item text-danger",
                              data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
                      </li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="card shadow-sm">
      <div class="card-body text-center py-5">
        <h2 class="h5 fw-bold mb-2">No searches yet</h2>
        <p class="text-secondary mb-4">Start sourcing by creating your first search.</p>
        <%= link_to "New search", new_search_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
